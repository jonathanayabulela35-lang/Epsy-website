import { supabase } from "@/lib/supabaseClient";

export const ADMIN_EMAIL =
  import.meta.env.VITE_ADMIN_EMAIL || "ayabulelaplatana126@gmail.com";

export function isAdminMode() {
  return new URLSearchParams(window.location.search).get("admin") === "1";
}

export async function getSession() {
  const { data } = await supabase.auth.getSession();
  return data.session;
}

export function isAdminSession(session) {
  const email = session?.user?.email?.toLowerCase() || "";
  return email === ADMIN_EMAIL.toLowerCase();
}

export async function sendMagicLink(email, redirectPathWithAdmin = "/?admin=1") {
  const { error } = await supabase.auth.signInWithOtp({
    email,
    options: { emailRedirectTo: window.location.origin + redirectPathWithAdmin },
  });
  if (error) throw error;
}

export async function signOut() {
  const { error } = await supabase.auth.signOut();
  if (error) throw error;
}